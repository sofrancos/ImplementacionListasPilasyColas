public class DynamicArray {

    private int[] datos;
    private int tamaño;
    private int capacidad;

    // Constructor por defecto
    public DynamicArray() {
        this.capacidad = 10;
        this.datos = new int[capacidad];
        this.tamaño = 0;
    }

    // Constructor con capacidad inicial
    public DynamicArray(int capacidadInicial) {
        if (capacidadInicial <= 0) {
            throw new IllegalArgumentException("La capacidad debe ser mayor a 0");
        }
        this.capacidad = capacidadInicial;
        this.datos = new int[capacidad];
        this.tamaño = 0;
    }

    // Agrega al final
    public void add(int valor) {
        if (tamaño == capacidad) {
            resize(capacidad * 2);
        }
        datos[tamaño] = valor;
        tamaño++;
    }

    // Inserta en posición específica
    public void addAt(int indice, int valor) {
        if (indice < 0 || indice > tamaño) {
            throw new IndexOutOfBoundsException();
        }

        if (tamaño == capacidad) {
            resize(capacidad * 2);
        }

        for (int i = tamaño; i > indice; i--) {
            datos[i] = datos[i - 1];
        }

        datos[indice] = valor;
        tamaño++;
    }

    // Elimina el último elemento
    public void removeLast() {
        if (isEmpty()) {
            throw new IllegalStateException("El arreglo está vacío");
        }

        tamaño--;

        // Reducción opcional de capacidad
        if (tamaño > 0 && tamaño == capacidad / 4) {
            resize(capacidad / 2);
        }
    }

    // Elimina en posición específica
    public void removeAt(int indice) {
        if (indice < 0 || indice >= tamaño) {
            throw new IndexOutOfBoundsException();
        }

        for (int i = indice; i < tamaño - 1; i++) {
            datos[i] = datos[i + 1];
        }

        tamaño--;

        if (tamaño > 0 && tamaño == capacidad / 4) {
            resize(capacidad / 2);
        }
    }

    // Obtiene elemento
    public int get(int indice) {
        if (indice < 0 || indice >= tamaño) {
            throw new IndexOutOfBoundsException();
        }
        return datos[indice];
    }

    // Modifica elemento
    public void set(int indice, int valor) {
        if (indice < 0 || indice >= tamaño) {
            throw new IndexOutOfBoundsException();
        }
        datos[indice] = valor;
    }

    // Retorna tamaño
    public int size() {
        return tamaño;
    }

    // Retorna capacidad
    public int capacity() {
        return capacidad;
    }

    // Verifica si está vacío
    public boolean isEmpty() {
        return tamaño == 0;
    }

    // Limpia el arreglo
    public void clear() {
        this.capacidad = 10;
        this.datos = new int[capacidad];
        this.tamaño = 0;
    }

    // Redimensiona el arreglo
    private void resize(int nuevaCapacidad) {
        int[] nuevoArreglo = new int[nuevaCapacidad];

        for (int i = 0; i < tamaño; i++) {
            nuevoArreglo[i] = datos[i];
        }

        datos = nuevoArreglo;
        capacidad = nuevaCapacidad;
    }
}
